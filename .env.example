# Copy this file to `.env` and fill in your values.

# --- Groq / Qwen ---------------------------------------------------------
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Qwen model served by Groq. qwen/qwen3-32b was flagged for deprecation
# (2026-06-17), so we default to the current Qwen model. Override freely.
GROQ_MODEL=qwen/qwen3.6-27b

# --- SQL execution backend ----------------------------------------------
# sqlite  -> built-in Python engine, zero setup (default)
# mysql   -> real MySQL server (requires PyMySQL + SQLAlchemy, see requirements.txt)
DB_BACKEND=sqlite

# Only used when DB_BACKEND=mysql. Example:
# mysql+pymysql://user:password@127.0.0.1:3306/sqlcourse
MYSQL_URL=

# --- Server --------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
